{
  "name": "cabine-2-0",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":          "concurrently -n \"API,UI\" -c \"blue,green\" \"node server.js\" \"vite\"",
    "dev:ui":       "vite",
    "dev:api":      "node server.js",
    "build":        "vite build",
    "preview":      "vite preview",
    "start":        "node server.js",
    "lint":         "eslint .",

    "cap:build":    "npm run build && npx cap sync android",
    "cap:android":  "npx cap open android",
    "cap:run":      "npm run build && npx cap sync android && npx cap run android",
    "cap:init":     "npx cap add android"
  },
  "dependencies": {
    "@capacitor/android":      "^7.2.0",
    "@capacitor/app":          "^7.0.1",
    "@capacitor/core":         "^7.2.0",
    "@capacitor/haptics":      "^7.0.1",
    "@capacitor/keyboard":     "^7.0.1",
    "@capacitor/network":      "^7.0.1",
    "@capacitor/share":        "^7.0.1",
    "@capacitor/splash-screen":"^7.0.1",
    "@capacitor/status-bar":   "^7.0.1",
    "bcrypt":     "^6.0.0",
    "cors":       "^2.8.6",
    "dotenv":     "^17.4.2",
    "express":    "^5.2.1",
    "html2canvas":"^1.4.1",
    "lucide-react":"^1.11.0",
    "pg":         "^8.20.0",
    "react":      "^19.2.5",
    "react-dom":  "^19.2.5",
    "sqlite3":    "^6.0.1",
    "uuid":       "^14.0.0"
  },
  "devDependencies": {
    "@capacitor/cli":             "^7.2.0",
    "@eslint/js":                 "^10.0.1",
    "@types/react":               "^19.2.14",
    "@types/react-dom":           "^19.2.3",
    "@vitejs/plugin-react":       "^6.0.1",
    "concurrently":               "^9.2.1",
    "eslint":                     "^10.2.1",
    "eslint-plugin-react-hooks":  "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals":                    "^17.5.0",
    "vite":                       "^8.0.10"
  }
}
